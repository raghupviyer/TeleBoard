# Gemini configuration (Preferred)
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama configuration (Local)
# OLLAMA_MODEL=gemma4:latest
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenAI configuration (Optional fallback)
# OPENAI_API_KEY=your-openai-key-here

# Telegram configuration (Option A: Bot API Polling)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: comma-separated list of individual chat IDs to receive private approval prompts
# TELEGRAM_APPROVER_IDS=123456789,987654321

# Telegram configuration (Option B: User Client via Telethon)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Ticketing Sync Provider (jira or openproject)
SYNC_PROVIDER=jira

# Jira configuration
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=your-jira-account-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=BUG
# Default active Sprint ID to assign new issues (e.g. 2 for Sprint 0)
# JIRA_DEFAULT_SPRINT_ID=

# OpenProject configuration
OPENPROJECT_HOST=https://your-openproject-instance.com
OPENPROJECT_API_KEY=your-personal-access-token-here
OPENPROJECT_PROJECT_ID=your-project-identifier-or-id-here

# Continuous Execution Settings
CONTINUOUS_MODE=true
POLL_INTERVAL_SECONDS=10
